NODE_ENV=development
DATABASE_URL="postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE_NAME"
PORT=5004
BCRYPT_SALT_ROUNDS=12

# Mail sending credentials
NODEMAILER_EMAIL=your-email@example.com
NODEMAILER_PASSWORD=your-app-password

# Security
JWT_ACCESS_SECRET=your-jwt-access-secret
EXPIRES_IN=10d
JWT_REFRESH_SECRET=your-jwt-refresh-secret
REFRESH_EXPIRES_IN=30d
RESET_PASS_TOKEN=your-reset-password-token
RESET_PASS_TOKEN_EXPIRES_IN=1d

# Frontend / backend URLs
FRONTEND_URL=http://localhost:3000
BACKEND_IMAGE_URL=http://localhost:5004/uploads
RESET_PASS_LINK=http://localhost:3000/reset-password

# Stripe
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
ONBOARDING_REFRESH_URL=http://localhost:5173/stripe/onboarding/refresh
ONBOARDING_RETURN_URL=http://localhost:5173/stripe/onboarding/return
CHECKOUT_SUCCESS_URL=http://localhost:3000/payment/success
CHECKOUT_CANCEL_URL=http://localhost:3000/payment/cancel

# Cloudinary
CLOUDINARY_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Paystack
PAYSTACK_PUBLISHABLE_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# DigitalOcean Spaces
DO_SPACE_ENDPOINT=
DO_SPACE_ACCESS_KEY=
DO_SPACE_SECRET_KEY=
DO_SPACE_BUCKET=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Flutterwave
FLUTTERWAVE_PUBLISHABLE_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
CURRENCY=USD
OWNER_PAYOUT_PERCENT=80
OWNER_COMMISSION_PERCENT=20

# AWS S3 bucket
AWS_BUCKET_ACCESS_KEY=
AWS_BUCKET_SECRET_KEY=
AWS_BUCKET_REGION=
AWS_BUCKET_NAME=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379
