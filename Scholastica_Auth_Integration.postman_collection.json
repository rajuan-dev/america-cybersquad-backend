{
  "info": {
    "_postman_id": "d8c9a0c2-1bd5-4de8-8e9a-1e7fc2a9a111",
    "name": "Scholastica Auth Integration",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "End-to-end auth flow aligned with the current frontend: sign up, sign in, refresh token, and fetch profile."
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('email')) {",
          "  pm.collectionVariables.set('email', `scholarstika.${Date.now()}@example.com`);",
          "}",
          "if (!pm.collectionVariables.get('password')) {",
          "  pm.collectionVariables.set('password', 'StrongPass!234');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5004"
    },
    {
      "key": "email",
      "value": ""
    },
    {
      "key": "password",
      "value": "StrongPass!234"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Frontend Integration User\",\n  \"email\": \"{{email}}\",\n  \"schoolName\": \"Scholarstika Demo School\",\n  \"password\": \"{{password}}\",\n  \"role\": \"INSTITUTIONAL_OWNER\",\n  \"country\": \"Bangladesh\",\n  \"city\": \"Dhaka\",\n  \"state\": \"Dhaka\",\n  \"branches\": 3\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/create_user",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "users",
            "create_user"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('signup returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "pm.test('signup is successful', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.success).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.test('login returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.collectionVariables.set('accessToken', json.data.accessToken);",
              "pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
              "pm.test('login returns both tokens', function () {",
              "  pm.expect(json.data.accessToken).to.be.a('string');",
              "  pm.expect(json.data.refreshToken).to.be.a('string');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Refresh Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/refresh-token",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "refresh-token"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.test('refresh token returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.collectionVariables.set('accessToken', json.data.accessToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "4. My Profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/my-profile",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "my-profile"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('my-profile returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('my-profile returns expected email', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.data.email).to.eql(pm.collectionVariables.get('email'));",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
