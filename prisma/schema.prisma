datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  STUDENT
  PARENT
  TEACHER
  ADMIN
  SUPER_ADMIN
  INSTITUTIONAL_OWNER
 

}

enum UserStatus {
  ACTIVE
  INACTIVE
  REJECTED
}

model Questions {
  id          String   @id @default(uuid())
  owner       Boolean
  typeOfOwner String
  branches    Int
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("questions")
}

model User {
  id String @id @default(uuid())

  name             String?
  email            String     @unique
  password         String
  photo            String?
  country          String
  city             String
  schoolName       String?
  role             UserRole   @default(STUDENT)
  status           UserStatus @default(ACTIVE)
  verificationCode Int?       @unique
  isVerified       Boolean    @default(false)
  fcm              String?

  isDeleted     Boolean         @default(false)
  questions     Questions?
  subscriptions Subscriptions[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("users")
}

model Contact {
  id          String @id @default(uuid())
  name        String
  email       String
  phoneNumber String
  subject     String
  message     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([email])
  @@index([phoneNumber])
  @@map("contacts")
}

model Testimonials {
  id           String  @id @default(uuid())
  name         String  @db.VarChar(100)
  designation  String  @db.VarChar(100)
  workingPlace String  @db.VarChar(150)
  videoUrl     String? @db.VarChar(255)
  isDeleted    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([designation])
  @@map("testimonials")
}

model Subscriptions {
  id              String   @id @default(uuid())
  country         String
  countryCategory String
  locationType    String
  studentLimit    Int
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  price           Float
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([country])
  @@index([countryCategory])
  @@map("subscriptions")
}

model Admin {
  id          String  @id @default(uuid())
  fullName    String?
  phoneNumber String?
  email       String  @unique
  password    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

