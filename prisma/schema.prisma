// ---------------------------
// Datasource & Generator
// ---------------------------
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------
// Enums
// ---------------------------
enum UserRole {
  STUDENT
  PARENT
  TEACHER
  ADMIN
  SUPER_ADMIN
  INSTITUTIONAL_OWNER
  BRANCH_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  REJECTED
}

model User {
  id String @id @default(uuid())

  name             String?
  email            String     @unique
  password         String
  photo            String?
  country          String
  city             String
  state            String?
  schoolName       String?
  role             UserRole   @default(STUDENT)
  status           UserStatus @default(ACTIVE)
  verificationCode Int?       @unique
  isVerified       Boolean    @default(false)
  fcm              String?
  branches         Int
  isDeleted        Boolean    @default(false)

  subscriptions Subscriptions[]
  branchadmins  BranchAdmin[]
  announcements Announcement[]
  notification  Notification[]
  supports      Support[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Contact {
  id          String @id @default(uuid())
  name        String
  email       String
  phoneNumber String
  subject     String
  message     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([email])
  @@index([phoneNumber])
  @@map("contacts")
}

model Testimonials {
  id           String  @id @default(uuid())
  name         String  @db.VarChar(100)
  designation  String  @db.VarChar(100)
  workingPlace String  @db.VarChar(150)
  videoUrl     String? @db.VarChar(255)
  isDeleted    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([designation])
  @@map("testimonials")
}

enum SubscriptionType {
  free_trial
  paid
}

enum SchoolArea {
  Urban
  Rural
}

model Subscriptions {
  id                  String                @id @default(uuid())
  userId              String
  user                User                  @relation(fields: [userId], references: [id])
  price               Float                 @default(0.00)
  isDeleted           Boolean               @default(false)
  subscriptiondetails SubscriptionDetails[]
  student             Student[]
  teacher             Teacher[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  announcements       Announcement[]
  notifications       Notification[]
  supports            Support[]
  staffs              Staff[]

  @@index([price])
  @@map("subscriptions")
}

model SubscriptionDetails {
  id               String           @id @default(uuid())
  subscriptionType SubscriptionType
  subscriptionId   String           @db.VarChar(100)
  subscriptions    Subscriptions    @relation(fields: [subscriptionId], references: [id])
  schoolName       String           @db.VarChar(100)
  country          String           @db.VarChar(100)
  state            String           @db.VarChar(100)
  city             String           @db.VarChar(100)
  area             SchoolArea
  schoolType       String           @db.VarChar(100)
  studentLimit     String           @db.VarChar(100)
  isDeleted        Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([schoolName])
  @@index([country])
  @@index([state])
  @@index([city])
  @@index([area])
  @@index([schoolType])
  @@map("subscriptiondetails")
}

model BranchAdmin {
  id               String         @id @default(uuid())
  fullName         String
  phoneNumber      String         @unique
  emailAddress     String         @unique
  password         String
  photo            String?
  verificationCode Int?           @unique
  role             String
  joinDate         DateTime
  assignBranch     String         @unique
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  students         Student[]
  teachers         Teacher[]
  announcements    Announcement[]
  notification     Notification[]
  supports         Support[]
  isDeleted        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([fullName])
  @@index([phoneNumber])
  @@index([role])
  @@index([emailAddress])
  @@index([assignBranch])
  @@index([verificationCode])
  @@map("branchadmins")
}

model Student {
  id               String         @id @default(uuid())
  name             String
  email            String         @unique
  branchName       String
  className        String
  guardianName     String
  guardianPhone    String
  password         String
  studentId        String         @unique
  verificationCode Int?           @unique
  isVerified       Boolean        @default(true)
  branchAdminId    String
  branchAdmin      BranchAdmin    @relation(fields: [branchAdminId], references: [id])
  subscriptions    Subscriptions  @relation(fields: [subscriptionId], references: [id])
  // announcements    Announcement[]
  notification     Notification[]
  subscriptionId   String
  photo            String?
  isDeleted        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([name])
  @@index([email])
  @@index([branchName])
  @@index([className])
  @@index([guardianName])
  @@index([guardianPhone])
  @@index([verificationCode])
  @@map("students")
}

model Teacher {
  id             String         @id @default(uuid())
  teacherName    String
  teacherId      String         @unique
  email          String         @unique
  phoneNumber    String         @unique
  branchName     String
  subject        String[]
  assignClass    String[]
  password       String
  address        String
  photo          String?
  isDeleted      Boolean        @default(false)
  subscriptionId String
  branchAdminId  String
  branchAdmin    BranchAdmin    @relation(fields: [branchAdminId], references: [id])
  subscriptions  Subscriptions  @relation(fields: [subscriptionId], references: [id])
  announcements  Announcement[]
  notification   Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherName])
  @@index([email])
  @@index([phoneNumber])
  @@index([branchName])
  @@index([subject])
  @@index([assignClass])
  @@map("teachers")
}

// ---------------------------
// Announcement
// ---------------------------
model Announcement {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(100)
  description String   @db.VarChar(300)
  audience    String[]

  userId        String?
  branchAdminId String?
  studentId     String?
  teacherId     String?

  subscriptionId String
  subscriptions  Subscriptions @relation(fields: [subscriptionId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])
  branchAdmin    BranchAdmin?  @relation(fields: [branchAdminId], references: [id])
  // student     Student?     @relation(fields: [studentId], references: [id])
  teacher        Teacher?      @relation(fields: [teacherId], references: [id])

  // Parent field pending

  isDelete  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

// ---------------------------
// Notification 
// ---------------------------

model Notification {
  id             String         @id @default(uuid())
  title          String
  message        String
  isRead         Boolean        @default(false)
  route          String?
  userId         String?
  branchAdminId  String?
  studentId      String?
  teacherId      String?
  subscriptionId String
  subscriptions  Subscriptions? @relation(fields: [subscriptionId], references: [id])

  user        User?        @relation(fields: [userId], references: [id])
  branchAdmin BranchAdmin? @relation(fields: [branchAdminId], references: [id])
  student     Student?     @relation(fields: [studentId], references: [id])
  teacher     Teacher?     @relation(fields: [teacherId], references: [id])
  // Parent field pending
  isDelete    Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  support   Support? @relation(fields: [supportId], references: [id])
  supportId String?

  @@map("notifications")
}

model Support {
  id String @id @default(uuid())

  name           String
  email          String
  subject        String
  message        String
  subscriptionId String?
  subscriptions  Subscriptions? @relation(fields: [subscriptionId], references: [id]) // ✅ Added ?
  branchAdminId  String?
  branchAdmin    BranchAdmin?   @relation(fields: [branchAdminId], references: [id])
  userId         String?
  user           User?          @relation(fields: [userId], references: [id])
  notifications  Notification[]

  isDelete Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([email])
  @@index([subscriptionId])
  @@index([branchAdminId])
  @@index([userId])
  @@map("supports")
}

model Staff {
  id             String         @id @default(uuid())
  name           String         @db.VarChar(100)
  role           String         @db.VarChar(100)
  email          String         @db.VarChar(100)
  phoneNumber    String         @db.VarChar(100)
  password       String         @db.VarChar(300)
  generateId     String         @unique @db.VarChar(100)
  subscriptionId String
  photo          String?
  subscriptions  Subscriptions? @relation(fields: [subscriptionId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([name])
  @@index([email])
  @@index([role])
  @@index([phoneNumber])
  @@map("staffs")
}

model Admin {
  id          String  @id @default(uuid())
  fullName    String?
  phoneNumber String?
  email       String  @unique
  password    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}
