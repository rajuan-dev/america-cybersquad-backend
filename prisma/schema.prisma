generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(uuid())
  name             String?
  email            String          @unique
  password         String
  photo            String?
  country          String
  city             String
  state            String?
  schoolName       String?
  role             UserRole        @default(STUDENT)
  status           UserStatus      @default(ACTIVE)
  verificationCode Int?            @unique
  isVerified       Boolean         @default(false)
  fcm              String?
  isDeleted        Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  branches         Int
  announcements    Announcement[]
  branchadmins     BranchAdmin[]
  notification     Notification[]
  subscriptions    Subscriptions[]
  supports         Support[]

  @@map("users")
}

model Contact {
  id          String   @id @default(uuid())
  name        String
  email       String
  phoneNumber String
  subject     String
  message     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([email])
  @@index([phoneNumber])
  @@map("contacts")
}

model Testimonials {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(100)
  designation  String   @db.VarChar(100)
  workingPlace String   @db.VarChar(150)
  videoUrl     String?  @db.VarChar(255)
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([name])
  @@index([designation])
  @@map("testimonials")
}

