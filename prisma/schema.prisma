// ---------------------------
// Datasource & Generator
// ---------------------------
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------
// Enums
// ---------------------------
enum UserRole {
  STUDENT
  PARENT
  TEACHER
  ADMIN
  SUPER_ADMIN
  INSTITUTIONAL_OWNER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  REJECTED
}

// ---------------------------
// Models
// ---------------------------

model User {
  id String @id @default(uuid())

  name             String?
  email            String     @unique
  password         String
  photo            String?
  country          String
  city             String
  state            String?
  region           String?
  province         String?
  schoolName       String?
  role             UserRole   @default(STUDENT)
  status           UserStatus @default(ACTIVE)
  verificationCode Int?       @unique
  isVerified       Boolean    @default(false)
  fcm              String?

  isDeleted      Boolean       @default(false)
  questions      Questions?
  subscriptions  Subscriptions[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("users")
}

model Questions {
  id          String   @id @default(uuid())
  owner       Boolean
  typeOfOwner String
  branches    Int
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("questions")
}

model Contact {
  id          String @id @default(uuid())
  name        String
  email       String
  phoneNumber String
  subject     String
  message     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([email])
  @@index([phoneNumber])
  @@map("contacts")
}

model Testimonials {
  id           String  @id @default(uuid())
  name         String  @db.VarChar(100)
  designation  String  @db.VarChar(100)
  workingPlace String  @db.VarChar(150)
  videoUrl     String? @db.VarChar(255)
  isDeleted    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([designation])
  @@map("testimonials")
}

model Subscriptions {
  id                  String                 @id @default(uuid())
  studentLimit        Int
  userId              String
  user                User                   @relation(fields: [userId], references: [id])
  price               Float
  isDeleted           Boolean                @default(false)
  subscriptiondetails SubscriptionDetails[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@map("subscriptions")
}

model SubscriptionDetails {
  id              String        @id @default(uuid())
  branchName      String
  locationContext String
  subscriptionId  String
  subscriptions   Subscriptions @relation(fields: [subscriptionId], references: [id])
  student         Int
  state           String
  region          String
  province        String
  city            String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([branchName])
  @@index([locationContext])
  @@index([student])
  @@index([state])
  @@index([region])
  @@index([province])
  @@index([city])
  @@map("subscriptiondetails")
}

model Admin {
  id          String  @id @default(uuid())
  fullName    String?
  phoneNumber String?
  email       String  @unique
  password    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}