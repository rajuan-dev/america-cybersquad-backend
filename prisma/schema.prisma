datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  STUDENT
  PARENT
  TEACHER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  REJECTED
}

model User {
  id String @id @default(uuid())

  name     String?
  email    String  @unique
  password String
  photo    String?
  country  String
  city     String

  role             UserRole   @default(STUDENT)
  status           UserStatus @default(ACTIVE)
  verificationCode Int?       @unique
  isVerified       Boolean    @default(false)
  fcm              String?

  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Contact {
  id          String   @id @default(uuid())
  name        String
  email       String
  phoneNumber String
  subject     String
  message     String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("contacts")
}


model Admin {
  id          String  @id @default(uuid())
  fullName    String?
  phoneNumber String?
  email       String  @unique
  password    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}
