generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(uuid())
  name             String?
  email            String          @unique
  password         String
  photo            String?
  country          String
  city             String
  state            String?
  schoolName       String?
  role             UserRole        @default(STUDENT)
  status           UserStatus      @default(ACTIVE)
  verificationCode Int?            @unique
  isVerified       Boolean         @default(false)
  fcm              String?
  isDeleted        Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  branches         Int
  announcements    Announcement[]
  branchadmins     BranchAdmin[]
  notification     Notification[]
  subscriptions    Subscriptions[]
  supports         Support[]

  @@map("users")
}

model Contact {
  id          String   @id @default(uuid())
  name        String
  email       String
  phoneNumber String
  subject     String
  message     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([email])
  @@index([phoneNumber])
  @@map("contacts")
}

model Testimonials {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(100)
  designation  String   @db.VarChar(100)
  workingPlace String   @db.VarChar(150)
  videoUrl     String?  @db.VarChar(255)
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([name])
  @@index([designation])
  @@map("testimonials")
}

model Subscriptions {
  id                  String                @id @default(uuid())
  userId              String
  price               Float                 @default(0.00)
  isDeleted           Boolean               @default(false)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  announcements       Announcement[]
  notifications       Notification[]
  staffs              Staff[]
  student             Student[]
  subscriptiondetails SubscriptionDetails[]
  user                User                  @relation(fields: [userId], references: [id])
  supports            Support[]
  teacher             Teacher[]
  subjects            Subject[]
  // ✅ ONE TO ONE
  classDistribution ClassDistribution?


  @@index([price])
  @@map("subscriptions")
}

model SubscriptionDetails {
  id               String           @id @default(uuid())
  subscriptionId   String           @db.VarChar(100) 
  state            String           @db.VarChar(100)
  city             String           @db.VarChar(100)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  area             SchoolArea
  country          String           @db.VarChar(100)
  isDeleted        Boolean          @default(false)
  schoolName       String           @db.VarChar(100)
  schoolType       String           @db.VarChar(100)
  studentLimit     String           @db.VarChar(100)
  subscriptionType SubscriptionType
  subscriptions    Subscriptions    @relation(fields: [subscriptionId], references: [id])

  @@index([schoolName])
  @@index([country])
  @@index([state])
  @@index([city])
  @@index([area])
  @@index([schoolType])
  @@map("subscriptiondetails")
}

model BranchAdmin {
  id               String         @id @default(uuid())
  fullName         String
  phoneNumber      String         @unique
  emailAddress     String         @unique
  password         String
  photo            String?
  verificationCode Int?           @unique
  role             String
  joinDate         DateTime
  assignBranch     String         @unique
  userId           String
  isDeleted        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  announcements    Announcement[]
  user             User           @relation(fields: [userId], references: [id])
  notification     Notification[]
  students         Student[]
  supports         Support[]
  teachers         Teacher[]
  subjects         Subject[]

  @@index([fullName])
  @@index([phoneNumber])
  @@index([role])
  @@index([emailAddress])
  @@index([assignBranch])
  @@index([verificationCode])
  @@map("branchadmins")
}

model Student {
  id         String @id @default(uuid())
  name       String
  email      String @unique
  branchName String

  className         String
  guardianName      String
  guardianPhone     String
  password          String
  verificationCode  Int?                @unique
  isVerified        Boolean             @default(true)
  branchAdminId     String
  subscriptionId    String
  photo             String?
  isDeleted         Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  studentId         String
  role              String
  notification      Notification[]
   classDistributions ClassDistribution[]
  branchAdmin       BranchAdmin         @relation(fields: [branchAdminId], references: [id])
  subscriptions     Subscriptions       @relation(fields: [subscriptionId], references: [id])

  @@index([name])
  @@index([email])
  @@index([branchName])
  @@index([className])
  @@index([guardianName])
  @@index([guardianPhone])
  @@index([verificationCode])
  @@index([studentId])
  @@index([role])
  @@map("students")
}

model Teacher {
  id                String              @id @default(uuid())
  teacherName       String
  email             String              @unique
  phoneNumber       String              @unique
  branchName        String
  subject           String[]
  assignClass       String[]
  password          String
  address           String
  photo             String?
  isDeleted         Boolean             @default(false)
  subscriptionId    String
  branchAdminId     String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  teacherId         String
  role              String
  announcements     Announcement[]
  notification      Notification[]
  classDistributions ClassDistribution[]
  branchAdmin       BranchAdmin         @relation(fields: [branchAdminId], references: [id])
  subscriptions     Subscriptions       @relation(fields: [subscriptionId], references: [id])

  @@index([teacherName])
  @@index([email])
  @@index([phoneNumber])
  @@index([branchName])
  @@index([subject])
  @@index([assignClass])
  @@index([teacherId])
  @@index([role])
  @@map("teachers")
}

model ClassDistribution {
  id         String  @id @default(uuid())
  capacity   Int
  roomNumber String  @db.VarChar(20)
  teacherId  String  @db.VarChar(100)
  teacher    Teacher @relation(fields: [teacherId], references: [id])
  classLevel String  @db.VarChar(100)
  students   Student @relation(fields: [classLevel], references: [id])
  subscriptionId String  @db.VarChar(20) @unique
  subscriptions     Subscriptions       @relation(fields: [subscriptionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDelete  Boolean  @default(false)

  @@index([teacherId])
  @@index([classLevel])
  @@index([capacity])
  @@index([subscriptionId])
  @@map("class_distributions")
}

model Announcement {
  id             String        @id @default(uuid())
  title          String        @db.VarChar(100)
  description    String        @db.VarChar(300)
  audience       String[]
  userId         String?
  branchAdminId  String?
  studentId      String?
  teacherId      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  isDelete       Boolean       @default(false)
  subscriptionId String
  branchAdmin    BranchAdmin?  @relation(fields: [branchAdminId], references: [id])
  subscriptions  Subscriptions @relation(fields: [subscriptionId], references: [id])
  teacher        Teacher?      @relation(fields: [teacherId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@map("announcements")
}

model Notification {
  id             String        @id @default(uuid())
  title          String
  message        String
  isRead         Boolean       @default(false)
  route          String?
  userId         String?
  branchAdminId  String?
  studentId      String?
  teacherId      String?
  isDelete       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  subscriptionId String
  supportId      String?
  branchAdmin    BranchAdmin?  @relation(fields: [branchAdminId], references: [id])
  student        Student?      @relation(fields: [studentId], references: [id])
  subscriptions  Subscriptions @relation(fields: [subscriptionId], references: [id])
  support        Support?      @relation(fields: [supportId], references: [id])
  teacher        Teacher?      @relation(fields: [teacherId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Support {
  id             String         @id @default(uuid())
  name           String
  email          String
  subject        String
  message        String
  subscriptionId String?
  branchAdminId  String?
  userId         String?
  isDelete       Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  notifications  Notification[]
  branchAdmin    BranchAdmin?   @relation(fields: [branchAdminId], references: [id])
  subscriptions  Subscriptions? @relation(fields: [subscriptionId], references: [id])
  user           User?          @relation(fields: [userId], references: [id])

  @@index([name])
  @@index([email])
  @@index([subscriptionId])
  @@index([branchAdminId])
  @@index([userId])
  @@map("supports")
}

model Staff {
  id             String        @id @default(uuid())
  name           String        @db.VarChar(100)
  role           String        @db.VarChar(100)
  email          String        @db.VarChar(100)
  phoneNumber    String        @db.VarChar(100)
  password       String        @db.VarChar(300)
  generateId     String        @unique @db.VarChar(100)
  studentId      String?
  subscriptionId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  photo          String?
  subscriptions  Subscriptions @relation(fields: [subscriptionId], references: [id])

  @@index([name])
  @@index([role])
  @@index([phoneNumber])
  @@index([email])
  @@index([studentId])
  @@map("staffs")
}

model Subject {
  id             String @id @default(uuid())
  subjectName    String @db.VarChar(100)
  code           String @db.VarChar(20)
  department     String @db.VarChar(100)
  subscriptionId String

  subscriptions Subscriptions @relation(fields: [subscriptionId], references: [id])
  branchAdminId String
  branchAdmin   BranchAdmin   @relation(fields: [branchAdminId], references: [id])

  isDelete  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchAdminId])
  @@index([subjectName])
  @@index([code])
  @@index([department])
  @@index([subscriptionId])
  @@map("subjects")
}

model Admin {
  id          String   @id @default(uuid())
  fullName    String?
  phoneNumber String?
  email       String   @unique
  password    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("admins")
}

enum UserRole {
  STUDENT
  PARENT
  TEACHER
  ADMIN
  SUPER_ADMIN
  INSTITUTIONAL_OWNER
  BRANCH_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  REJECTED
}

enum SubscriptionType {
  free_trial
  paid
}

enum SchoolArea {
  Urban
  Rural
}
