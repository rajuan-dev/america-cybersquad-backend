model SubscriptionDetails {
  id               String           @id @default(uuid())
  subscriptionId   String           @db.VarChar(100)
  state            String           @db.VarChar(100)
  city             String           @db.VarChar(100)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  area             SchoolArea
  country          String           @db.VarChar(100)
  isDeleted        Boolean          @default(false)
  schoolName       String           @db.VarChar(100)
  schoolType       String           @db.VarChar(100)
  studentLimit     String           @db.VarChar(100)
  subscriptionType SubscriptionType
  subscriptions    Subscriptions    @relation(fields: [subscriptionId], references: [id])

  @@index([schoolName])
  @@index([country])
  @@index([state])
  @@index([city])
  @@index([area])
  @@index([schoolType])
  @@map("subscriptiondetails")
}

model BranchAdmin {
  id               String         @id @default(uuid())
  fullName         String
  phoneNumber      String         @unique
  emailAddress     String         @unique
  password         String
  photo            String?
  verificationCode Int?           @unique
  role             String
  joinDate         DateTime
  assignBranch     String
  userId           String
  isDeleted        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  subscriptionId   String?
  subscriptions    Subscriptions? @relation(fields: [subscriptionId], references: [id])
  announcements    Announcement[]
  user             User           @relation(fields: [userId], references: [id])
  notification     Notification[]
  students         Student[]
  supports         Support[]
  teachers         Teacher[]
  subjects         Subject[]

  @@index([fullName])
  @@index([phoneNumber])
  @@index([subscriptionId])
  @@index([role])
  @@index([emailAddress])
  @@index([assignBranch])
  @@index([verificationCode])
  @@map("branchadmins")
}

model Student {
  id         String @id @default(uuid())
  name       String
  email      String @unique
  branchName String
  className  String

  guardianName  String
  guardianPhone String
  password      String

  verificationCode Int?       @unique
  isVerified       Boolean    @default(true)
  status           UserStatus @default(ACTIVE)

  branchAdminId  String
  subscriptionId String

  photo     String?
  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentId String
  role      String

  classDistributions ClassDistribution[]

  // relations
  notification     Notification[]
  branchAdmin      BranchAdmin       @relation(fields: [branchAdminId], references: [id])
  subscriptions    Subscriptions     @relation(fields: [subscriptionId], references: [id])
  studentFees      StudentFees[]
  staffs           Staff[]
  attendanceSheets AttendanceSheet[]

  @@index([name])
  @@index([email])
  @@index([branchName])
  @@index([className])
  @@index([guardianName])
  @@index([guardianPhone])
  @@index([verificationCode])
  @@index([studentId])
  @@index([role])
  @@map("students")
}

model Teacher {
  id          String @id @default(uuid())
  teacherName String
  email       String @unique
  phoneNumber String @unique
  branchName  String

  subject     String[]
  assignClass String[]

  password String
  address  String
  photo    String?

  isDeleted Boolean @default(false)

  subscriptionId String
  branchAdminId  String

  isVerified Boolean    @default(true)
  status     UserStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherId String
  role      String

  announcements Announcement[]
  notification  Notification[]
  supports      Support[]

  classDistributions ClassDistribution[]
  attendanceSheets   AttendanceSheet[]
  branchAdmin        BranchAdmin         @relation(fields: [branchAdminId], references: [id])
  subscriptions      Subscriptions       @relation(fields: [subscriptionId], references: [id])

  @@map("teachers")
}

model ClassDistribution {
  id String @id @default(uuid())

  capacity          Int
  roomNumber        String
  classLevel        String
  assignableSubject String?
  //optional field 
  day               String?
  time              String?
  isOnline          Boolean? @default(false)

  // ✅ ONE teacher
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  // ✅ MANY students
  students         Student[]
  onlineClasses    OnlineClass[]
  classRecordings  ClassRecording[]
  classAssignments ClassAssignment[]
  classMaterials   ClassMaterial[]

  subscriptionId String
  subscriptions  Subscriptions @relation(fields: [subscriptionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  @@index([teacherId])
  @@index([classLevel])
  @@index([subscriptionId])
}

model Subscriptions {
  id     String @id @default(uuid())
  userId String

  price     Float   @default(0.00)
  isDeleted Boolean @default(false)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  feesManagements FeesManagement[]
  announcements   Announcement[]
  notifications   Notification[]
  staffs          Staff[]
  student         Student[]
  teacher         Teacher[]
  subjects        Subject[]
  supports        Support[]
  branchAdmins    BranchAdmin[]
  classMaterials  ClassMaterial[]

  subscriptiondetails SubscriptionDetails[]

  classDistributions ClassDistribution[]
  attendanceSheets   AttendanceSheet[]
  OnlineClasses      OnlineClass[]
  classRecordings    ClassRecording[]
  classAssignments   ClassAssignment[]

  user User @relation(fields: [userId], references: [id])

  @@map("subscriptions")
}

enum PaymentMethod {
  ONLINE
  MANUAL
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

model StudentFees {
  id String @id @default(uuid())

  paidAmount   Float @default(0)
  unpaidAmount Float

  paymentMethod PaymentMethod @default(MANUAL) // ✅ renamed
  paymentStatus PaymentStatus @default(UNPAID) // ✅ NEW

  studentId String
  userId    String
  student   Student @relation(fields: [userId], references: [id])

  feesManagementId String
  feesManagement   FeesManagement   @relation(fields: [feesManagementId], references: [id])
  paymentHistory   PaymentHistory[]
  isDelete         Boolean          @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ✅ Prevent duplicate fee per student per fees config
  @@unique([studentId, feesManagementId])
  @@index([studentId])
  @@index([feesManagementId])
  @@map("student_fees")
}

model FeesManagement {
  id             String        @id @default(uuid())
  totalFees      Float         @default(5000)
  classLevel     String
  subscriptionId String
  subscriptions  Subscriptions @relation(fields: [subscriptionId], references: [id])

  isDelete    Boolean       @default(false)
  studentFees StudentFees[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([classLevel])
  @@index([subscriptionId])
  @@map("fees_managements")
}

model PaymentHistory {
  id            String      @id @default(uuid())
  amount        Float
  studentFeesId String
  studentFees   StudentFees @relation(fields: [studentFeesId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([amount])
  @@index([studentFeesId])
  @@map("paymentHistory")
}

model Announcement {
  id             String        @id @default(uuid())
  title          String        @db.VarChar(100)
  description    String        @db.VarChar(300)
  audience       String[]
  userId         String?
  branchAdminId  String?
  studentId      String?
  teacherId      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  isDelete       Boolean       @default(false)
  subscriptionId String
  branchAdmin    BranchAdmin?  @relation(fields: [branchAdminId], references: [id])
  subscriptions  Subscriptions @relation(fields: [subscriptionId], references: [id])
  teacher        Teacher?      @relation(fields: [teacherId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@map("announcements")
}

model Notification {
  id             String   @id @default(uuid())
  title          String
  message        String
  isRead         Boolean  @default(false)
  route          String?
  userId         String?
  branchAdminId  String?
  studentId      String?
  teacherId      String?
  isDelete       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  subscriptionId String
  supportId      String?

  branchAdmin   BranchAdmin?  @relation(fields: [branchAdminId], references: [id])
  student       Student?      @relation(fields: [studentId], references: [id])
  subscriptions Subscriptions @relation(fields: [subscriptionId], references: [id])
  support       Support?      @relation(fields: [supportId], references: [id])
  teacher       Teacher?      @relation(fields: [teacherId], references: [id])
  user          User?         @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Support {
  id             String         @id @default(uuid())
  name           String
  email          String
  subject        String
  message        String
  subscriptionId String?
  branchAdminId  String?
  userId         String?
  isDelete       Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  notifications  Notification[]
  teacherId      String?
  teachers       Teacher?       @relation(fields: [teacherId], references: [id])
  branchAdmin    BranchAdmin?   @relation(fields: [branchAdminId], references: [id])
  subscriptions  Subscriptions? @relation(fields: [subscriptionId], references: [id])
  user           User?          @relation(fields: [userId], references: [id])

  @@index([name])
  @@index([email])
  @@index([subscriptionId])
  @@index([branchAdminId])
  @@index([userId])
  @@map("supports")
}

model Staff {
  id             String        @id @default(uuid())
  name           String        @db.VarChar(100)
  role           String        @db.VarChar(100)
  email          String        @db.VarChar(100)
  phoneNumber    String        @db.VarChar(100)
  password       String        @db.VarChar(300)
  isVerified     Boolean       @default(true)
  status         UserStatus    @default(ACTIVE)
  generateId     String        @unique @db.VarChar(100)
  studentId      String?
  subscriptionId String
  sId            String?       @unique @db.VarChar(100)
  students       Student?      @relation(fields: [sId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  photo          String?
  subscriptions  Subscriptions @relation(fields: [subscriptionId], references: [id])

  @@index([name])
  @@index([role])
  @@index([phoneNumber])
  @@index([email])
  @@index([studentId])
  @@map("staffs")
}

model Subject {
  id             String @id @default(uuid())
  subjectName    String @db.VarChar(100)
  code           String @db.VarChar(20)
  department     String @db.VarChar(100)
  subscriptionId String

  subscriptions Subscriptions @relation(fields: [subscriptionId], references: [id])
  branchAdminId String
  branchAdmin   BranchAdmin   @relation(fields: [branchAdminId], references: [id])

  isDelete  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchAdminId])
  @@index([subjectName])
  @@index([code])
  @@index([department])
  @@index([subscriptionId])
  @@map("subjects")
}

model OnlineClass {
  id                  String            @id @default(uuid())
  classDistributionId String            @db.VarChar(255)
  classDistribution   ClassDistribution @relation(fields: [classDistributionId], references: [id])
  subscriptionId      String            @db.VarChar(255)
  subscriptions       Subscriptions     @relation(fields: [subscriptionId], references: [id])
  link                String            @db.VarChar(255)
  isDelete            Boolean           @default(false)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([classDistributionId])
  @@index([subscriptionId])
  @@index([link])
  @@map("online_classes")
}

model ClassRecording {
  id                  String            @id @default(uuid())
  classDistributionId String            @db.VarChar(255)
  classDistribution   ClassDistribution @relation(fields: [classDistributionId], references: [id])
  subscriptionId      String            @db.VarChar(255)
  subscriptions       Subscriptions     @relation(fields: [subscriptionId], references: [id])
  recordingUrl        String
  isDelete            Boolean           @default(false)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([classDistributionId])
  @@index([subscriptionId])
  @@index([recordingUrl])
  @@map("class_recordings")
}

enum AssignmentType {
  HomeWork
  Practice
  Project
  Quiz
}

model ClassAssignment {
  id                  String            @id @default(uuid())
  assignmentTitle     String            @db.VarChar(255)
  assignmentType      AssignmentType
  assignmentDueDate   DateTime
  description         String
  attachmentFiles     String[]
  assessmentAvailable Boolean           @default(false)
  classDistributionId String            @db.VarChar(255)
  classDistributions  ClassDistribution @relation(fields: [classDistributionId], references: [id])

  subscriptionId String        @db.VarChar(255)
  subscriptions  Subscriptions @relation(fields: [subscriptionId], references: [id])

  isDelete  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([classDistributionId])
  @@index([subscriptionId])
  @@index([assignmentType])
  @@index([assessmentAvailable])
  @@map("class_assignments")
}

enum ClassMaterialType {
  pdf
  word
  video
  external_link
}

model ClassMaterial {
  id String @id @default(uuid())

  materialType        ClassMaterialType
  description         String?
  materialFiles       String[]          @default([])
  external_link       String?
  classDistributionId String            @db.VarChar(255)
  classDistributions  ClassDistribution @relation(fields: [classDistributionId], references: [id])
  subscriptionId      String            @db.VarChar(255)
  subscriptions       Subscriptions     @relation(fields: [subscriptionId], references: [id])

  isDelete  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([materialType])
  @@index([classDistributionId])
  @@index([subscriptionId])
  @@map("class_materials")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

model AttendanceSheet {
  id String @id @default(uuid())

  AttendanceDate DateTime

  subscriptionId String
  teacherId      String
  studentId      String

  attendanceStatus AttendanceStatus @default(ABSENT)

  isDelete Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscriptions @relation(fields: [subscriptionId], references: [id])
  teachers      Teacher       @relation(fields: [teacherId], references: [id])
  students      Student       @relation(fields: [studentId], references: [id])

  @@unique([studentId, AttendanceDate, teacherId])
  @@index([teacherId])
  @@index([studentId])
  @@index([AttendanceDate])
  @@map("attendance_sheets")
}

model Admin {
  id          String   @id @default(uuid())
  fullName    String?
  phoneNumber String?
  email       String   @unique
  password    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("admins")
}

enum UserRole {
  STUDENT
  PARENT
  TEACHER
  ADMIN
  SUPER_ADMIN
  INSTITUTIONAL_OWNER
  BRANCH_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  REJECTED
}

enum SubscriptionType {
  free_trial
  paid
}

enum SchoolArea {
  Urban
  Rural
}
