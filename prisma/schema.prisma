// ---------------------------
// Datasource & Generator
// ---------------------------
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------
// Enums
// ---------------------------
enum UserRole {
  STUDENT
  PARENT
  TEACHER
  ADMIN
  SUPER_ADMIN
  INSTITUTIONAL_OWNER
  BRANCH_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  REJECTED
}

// ---------------------------
// Models
// ---------------------------

model User {
  id String @id @default(uuid())

  name             String?
  email            String     @unique
  password         String
  photo            String?
  country          String
  city             String
  state            String?
  region           String?
  province         String?
  schoolName       String?
  role             UserRole   @default(STUDENT)
  status           UserStatus @default(ACTIVE)
  verificationCode Int?       @unique
  isVerified       Boolean    @default(false)
  fcm              String?

  isDeleted     Boolean         @default(false)
  questions     Questions?
  subscriptions Subscriptions[]
  branchadmins  BranchAdmin[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("users")
}

model Questions {
  id          String   @id @default(uuid())
  owner       Boolean
  typeOfOwner String
  branches    Int
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("questions")
}

model Contact {
  id          String @id @default(uuid())
  name        String
  email       String
  phoneNumber String
  subject     String
  message     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([email])
  @@index([phoneNumber])
  @@map("contacts")
}

model Testimonials {
  id           String  @id @default(uuid())
  name         String  @db.VarChar(100)
  designation  String  @db.VarChar(100)
  workingPlace String  @db.VarChar(150)
  videoUrl     String? @db.VarChar(255)
  isDeleted    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([designation])
  @@map("testimonials")
}

model Subscriptions {
  id                  String                @id @default(uuid())
  studentLimit        Int
  userId              String
  user                User                  @relation(fields: [userId], references: [id])
  price               Float
  isDeleted           Boolean               @default(false)
  subscriptiondetails SubscriptionDetails[]
  student             Student[]
  teacher             Teacher[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@map("subscriptions")
}

model SubscriptionDetails {
  id              String        @id @default(uuid())
  branchName      String
  locationContext String
  subscriptionId  String
  subscriptions   Subscriptions @relation(fields: [subscriptionId], references: [id])
  student         Int
  state           String
  region          String
  province        String
  city            String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([branchName])
  @@index([locationContext])
  @@index([student])
  @@index([state])
  @@index([region])
  @@index([province])
  @@index([city])
  @@map("subscriptiondetails")
}

// branch admin model 

model BranchAdmin {
  id               String    @id @default(uuid())
  fullName         String
  phoneNumber      String    @unique
  emailAddress     String    @unique
  password         String
  photo            String?
  verificationCode Int?      @unique
  role             String
  joinDate         DateTime
  assignBranch     String    @unique
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  students         Student[]
  teachers         Teacher[]
  isDeleted        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([fullName])
  @@index([phoneNumber])
  @@index([role])
  @@index([emailAddress])
  @@index([assignBranch])
  @@index([verificationCode])
  @@map("branchadmins")
}

model Student {
  id               String        @id @default(uuid())
  name             String
  email            String        @unique
  branchName       String
  className        String
  guardianName     String
  guardianPhone    String
  password         String
  verificationCode Int?          @unique
  isVerified       Boolean       @default(true)
  branchAdminId    String
  branchAdmin      BranchAdmin   @relation(fields: [branchAdminId], references: [id])
  subscriptions    Subscriptions @relation(fields: [subscriptionId], references: [id])
  subscriptionId   String
  photo            String?
  isDeleted        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([name])
  @@index([email])
  @@index([branchName])
  @@index([className])
  @@index([guardianName])
  @@index([guardianPhone])
  @@index([verificationCode])
  @@map("students")
}

model Teacher {
  id          String  @id @default(uuid())
  teacherName  String
  email       String  @unique
  phoneNumber String  @unique
  branchName  String
  subject     String[]
  assignClass  String[]
  password    String
  address     String
  photo       String?
  isDeleted   Boolean @default(false)
  subscriptionId String
  branchAdminId    String
  branchAdmin      BranchAdmin   @relation(fields: [branchAdminId], references: [id])
  subscriptions Subscriptions @relation(fields: [subscriptionId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teachers")
  @@index([teacherName])
  @@index([email])
  @@index([phoneNumber])
  @@index([branchName])
  @@index([subject])
  @@index([assignClass])
  
}

model Admin {
  id          String  @id @default(uuid())
  fullName    String?
  phoneNumber String?
  email       String  @unique
  password    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}
