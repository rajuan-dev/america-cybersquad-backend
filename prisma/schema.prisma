generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(uuid())
  name             String?
  email            String          @unique
  password         String
  photo            String?
  country          String
  city             String
  state            String?
  schoolName       String?
  role             UserRole        @default(STUDENT)
  status           UserStatus      @default(ACTIVE)
  verificationCode Int?            @unique
  isVerified       Boolean         @default(false)
  fcm              String?
  isDeleted        Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  branches         Int
  announcements    Announcement[]
  branchadmins     BranchAdmin[]
  institutionBranches InstitutionBranch[]
  notification     Notification[]
  subscriptions    Subscriptions[]
  supports         Support[]

  @@map("users")
}

model Contact {
  id          String   @id @default(uuid())
  name        String
  email       String
  phoneNumber String
  subject     String
  message     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([email])
  @@index([phoneNumber])
  @@map("contacts")
}

model Testimonials {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(100)
  designation  String   @db.VarChar(100)
  workingPlace String   @db.VarChar(150)
  videoUrl     String?  @db.VarChar(255)
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([name])
  @@index([designation])
  @@map("testimonials")
}

model SubscriptionDetails {
  id               String           @id @default(uuid())
  subscriptionId   String           @db.VarChar(100)
  state            String           @db.VarChar(100)
  city             String           @db.VarChar(100)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  area             SchoolArea
  country          String           @db.VarChar(100)
  isDeleted        Boolean          @default(false)
  schoolName       String           @db.VarChar(100)
  schoolType       String           @db.VarChar(100)
  schoolPhoto      String ?
  studentLimit     String           @db.VarChar(100)
  subscriptionType SubscriptionType
  subscriptions    Subscriptions    @relation(fields: [subscriptionId], references: [id])

  @@index([schoolName])
  @@index([country])
  @@index([state])
  @@index([city])
  @@index([area])
  @@index([schoolType])
  @@map("subscriptiondetails")
}

model BranchAdmin {
  id               String         @id @default(uuid())
  fullName         String
  phoneNumber      String         @unique
  emailAddress     String         @unique
  password         String
  photo            String?
  status           UserStatus     @default(ACTIVE)
  isVerified       Boolean        @default(true)
  verificationCode Int?           @unique
  role             String
  joinDate         DateTime
  assignBranch     String
  userId           String
  isDeleted        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  subscriptionId   String?
  announcements    Announcement[]
  subscriptions    Subscriptions? @relation(fields: [subscriptionId], references: [id])
  user             User           @relation(fields: [userId], references: [id])
  notification     Notification[]
  students         Student[]
  subjects         Subject[]
  supports         Support[]
  teachers         Teacher[]

  @@index([fullName])
  @@index([phoneNumber])
  @@index([subscriptionId])
  @@index([role])
  @@index([emailAddress])
  @@index([assignBranch])
  @@index([verificationCode])
  @@index([status])
  @@index([isVerified])
  @@map("branchadmins")
}

model Student {
  id                 String              @id @default(uuid())
  name               String
  email              String              @unique
  branchName         String
  className          String
  guardianName       String
  guardianPhone      String
  password           String
  verificationCode   Int?                @unique
  isVerified         Boolean             @default(true)
  branchAdminId      String
  subscriptionId     String
  photo              String?
  isDeleted          Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  studentId          String
  role               String
  status             UserStatus          @default(ACTIVE)
  attendanceSheets   AttendanceSheet[]
  notification       Notification[]
  staffs             Staff?
  studentFees        StudentFees[]
  supports           Support[]
  branchAdmin        BranchAdmin         @relation(fields: [branchAdminId], references: [id])
  subscriptions      Subscriptions       @relation(fields: [subscriptionId], references: [id])
  submitAssignments  SubmitAssignment[]
  classDistributions ClassDistribution[] @relation("ClassDistributionToStudent")
  examGrades         ExamGrades[]
  healthRecords      HealthRecords[]

  @@index([name])
  @@index([email])
  @@index([branchName])
  @@index([className])
  @@index([guardianName])
  @@index([guardianPhone])
  @@index([verificationCode])
  @@index([studentId])
  @@index([role])
  @@map("students")
}

model Teacher {
  id                 String              @id @default(uuid())
  teacherName        String
  email              String              @unique
  phoneNumber        String              @unique
  branchName         String
  subject            String[]
  assignClass        String[]
  password           String
  address            String
   verificationCode   Int?                @unique
  photo              String?
  isDeleted          Boolean             @default(false)
  subscriptionId     String
  branchAdminId      String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  teacherId          String
  role               String
  isVerified         Boolean             @default(true)
  status             UserStatus          @default(ACTIVE)
  classDistributions ClassDistribution[]
  announcements      Announcement[]
  attendanceSheets   AttendanceSheet[]
  notification       Notification[]
  supports           Support[]
  branchAdmin        BranchAdmin         @relation(fields: [branchAdminId], references: [id])
  subscriptions      Subscriptions       @relation(fields: [subscriptionId], references: [id])
  examGrades         ExamGrades[]

  @@map("teachers")
}

model ClassDistribution {
  id                String             @id @default(uuid())
  capacity          Int
  roomNumber        String
  classLevel        String
  teacherId         String
  subscriptionId    String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  isDeleted         Boolean            @default(false)
  assignableSubject String?
  day               String?
  time              String?
  isOnline          Boolean?           @default(false)
  subscriptions     Subscriptions      @relation(fields: [subscriptionId], references: [id])
  teacher           Teacher            @relation(fields: [teacherId], references: [id])
  classAssignments  ClassAssignment[]
  classMaterials    ClassMaterial[]
  classRecordings   ClassRecording[]
  onlineClasses     OnlineClass[]
  students          Student[]          @relation("ClassDistributionToStudent")
  examAnnouncement  ExamAnnouncement[]

  @@index([teacherId])
  @@index([classLevel])
  @@index([subscriptionId])
}

model Subscriptions {
  id                  String                @id @default(uuid())
  userId              String
  price               Float                 @default(0.00)
  isDeleted           Boolean               @default(false)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  classDistributions  ClassDistribution[]
  announcements       Announcement[]
  attendanceSheets    AttendanceSheet[]
  branchAdmins        BranchAdmin[]
  classAssignments    ClassAssignment[]
  classMaterials      ClassMaterial[]
  classRecordings     ClassRecording[]
  feesManagements     FeesManagement[]
  notifications       Notification[]
  OnlineClasses       OnlineClass[]
  staffs              Staff[]
  student             Student[]
  subjects            Subject[]
  subscriptiondetails SubscriptionDetails[]
  user                User                  @relation(fields: [userId], references: [id])
  supports            Support[]
  teacher             Teacher[]
  examAnnouncement    ExamAnnouncement[]
  healthRecords       HealthRecords[]
  institutionBranches InstitutionBranch[]

  @@map("subscriptions")
}

model InstitutionBranch {
  id                 String        @id @default(uuid())
  userId             String
  subscriptionId     String?
  subscriptionDetailId String?     @unique
  name               String
  type               String
  location           String
  contact            String?
  annualPriceUsd     Float         @default(0)
  pricingRuleVersion String?
  isOverridden       Boolean       @default(false)
  overrideReason     String?
  isDeleted          Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  user               User          @relation(fields: [userId], references: [id])
  subscription       Subscriptions? @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([subscriptionId])
  @@index([name])
  @@map("institution_branches")
}

model StudentFees {
  id               String           @id @default(uuid())
  paidAmount       Float            @default(0)
  unpaidAmount     Float
  studentId        String
  userId           String
  feesManagementId String
  isDelete         Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  paymentMethod    PaymentMethod    @default(MANUAL)
  paymentStatus    PaymentStatus    @default(UNPAID)
  paymentHistory   PaymentHistory[]
  feesManagement   FeesManagement   @relation(fields: [feesManagementId], references: [id])
  student          Student          @relation(fields: [userId], references: [id])

  @@unique([studentId, feesManagementId])
  @@index([studentId])
  @@index([feesManagementId])
  @@map("student_fees")
}

model FeesManagement {
  id             String        @id @default(uuid())
  totalFees      Float         @default(5000)
  classLevel     String
  subscriptionId String
  isDelete       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  subscriptions  Subscriptions @relation(fields: [subscriptionId], references: [id])
  studentFees    StudentFees[]

  @@index([classLevel])
  @@index([subscriptionId])
  @@map("fees_managements")
}

model PaymentHistory {
  id            String      @id @default(uuid())
  amount        Float
  studentFeesId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  studentFees   StudentFees @relation(fields: [studentFeesId], references: [id])

  @@index([amount])
  @@index([studentFeesId])
  @@map("paymentHistory")
}

model Announcement {
  id             String        @id @default(uuid())
  title          String        @db.VarChar(100)
  description    String        @db.VarChar(300)
  audience       String[]
  userId         String?
  branchAdminId  String?
  studentId      String?
  teacherId      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  isDelete       Boolean       @default(false)
  subscriptionId String
  branchAdmin    BranchAdmin?  @relation(fields: [branchAdminId], references: [id])
  subscriptions  Subscriptions @relation(fields: [subscriptionId], references: [id])
  teacher        Teacher?      @relation(fields: [teacherId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@map("announcements")
}

model Notification {
  id             String        @id @default(uuid())
  title          String
  message        String
  isRead         Boolean       @default(false)
  route          String?
  userId         String?
  branchAdminId  String?
  studentId      String?
  teacherId      String?
  isDelete       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  subscriptionId String
  supportId      String?
  branchAdmin    BranchAdmin?  @relation(fields: [branchAdminId], references: [id])
  student        Student?      @relation(fields: [studentId], references: [id])
  subscriptions  Subscriptions @relation(fields: [subscriptionId], references: [id])
  support        Support?      @relation(fields: [supportId], references: [id])
  teacher        Teacher?      @relation(fields: [teacherId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Support {
  id             String         @id @default(uuid())
  name           String
  email          String
  subject        String
  message        String
  subscriptionId String?
  branchAdminId  String?
  userId         String?
  isDelete       Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  teacherId      String?
  studentId      String?
  parentId       String?
  notifications  Notification[]
  branchAdmin    BranchAdmin?   @relation(fields: [branchAdminId], references: [id])
  subscriptions  Subscriptions? @relation(fields: [subscriptionId], references: [id])
  teachers       Teacher?       @relation(fields: [teacherId], references: [id])
  user           User?          @relation(fields: [userId], references: [id])
  students       Student?       @relation(fields: [studentId], references: [id])
  parents        Staff?         @relation(fields: [parentId], references: [id])

  @@index([name])
  @@index([email])
  @@index([subscriptionId])
  @@index([branchAdminId])
  @@index([userId])
  @@map("supports")
}

model Staff {
  id             String          @id @default(uuid())
  name           String          @db.VarChar(100)
  role           String          @db.VarChar(100)
  email          String          @db.VarChar(100)
  phoneNumber    String          @db.VarChar(100)
  password       String          @db.VarChar(300)
 verificationCode   Int?                @unique
  generateId     String          @unique @db.VarChar(100)
  subscriptionId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  photo          String?
  studentId      String?
  isVerified     Boolean         @default(true)
  status         UserStatus      @default(ACTIVE)
  sId            String?         @unique @db.VarChar(100)
  students       Student?        @relation(fields: [sId], references: [id])
  subscriptions  Subscriptions   @relation(fields: [subscriptionId], references: [id])
  support        Support[]
  healthRecords  HealthRecords[]

  @@index([name])
  @@index([role])
  @@index([phoneNumber])
  @@index([email])
  @@index([studentId])
  @@map("staffs")
}

model Subject {
  id             String        @id @default(uuid())
  subjectName    String        @db.VarChar(100)
  code           String        @db.VarChar(20)
  department     String        @db.VarChar(100)
  subscriptionId String
  branchAdminId  String
  isDelete       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  branchAdmin    BranchAdmin   @relation(fields: [branchAdminId], references: [id])
  subscriptions  Subscriptions @relation(fields: [subscriptionId], references: [id])

  @@index([branchAdminId])
  @@index([subjectName])
  @@index([code])
  @@index([department])
  @@index([subscriptionId])
  @@map("subjects")
}

model OnlineClass {
  id                  String            @id @default(uuid())
  classDistributionId String            @db.VarChar(255)
  subscriptionId      String            @db.VarChar(255)
  link                String            @db.VarChar(255)
  isDelete            Boolean           @default(false)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  classDistribution   ClassDistribution @relation(fields: [classDistributionId], references: [id])
  subscriptions       Subscriptions     @relation(fields: [subscriptionId], references: [id])

  @@index([classDistributionId])
  @@index([subscriptionId])
  @@index([link])
  @@map("online_classes")
}

model ClassRecording {
  id                  String            @id @default(uuid())
  classDistributionId String            @db.VarChar(255)
  subscriptionId      String            @db.VarChar(255)
  recordingUrl        String
  isDelete            Boolean           @default(false)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  classDistribution   ClassDistribution @relation(fields: [classDistributionId], references: [id])
  subscriptions       Subscriptions     @relation(fields: [subscriptionId], references: [id])

  @@index([classDistributionId])
  @@index([subscriptionId])
  @@index([recordingUrl])
  @@map("class_recordings")
}

model ClassAssignment {
  id                  String             @id @default(uuid())
  assignmentTitle     String             @db.VarChar(255)
  assignmentType      AssignmentType
  assignmentDueDate   DateTime
  description         String
  attachmentFiles     String[]
  assessmentAvailable Boolean            @default(false)
  classDistributionId String             @db.VarChar(255)
  subscriptionId      String             @db.VarChar(255)
  isDelete            Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  classDistributions  ClassDistribution  @relation(fields: [classDistributionId], references: [id])
  subscriptions       Subscriptions      @relation(fields: [subscriptionId], references: [id])
  submitAssignments   SubmitAssignment[]

  @@index([classDistributionId])
  @@index([subscriptionId])
  @@index([assignmentType])
  @@index([assessmentAvailable])
  @@map("class_assignments")
}

model SubmitAssignment {
  id                String                 @id @default(uuid())
  studentId         String
  classAssignmentId String
  isDelete          Boolean                @default(false)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  classAssignments  ClassAssignment        @relation(fields: [classAssignmentId], references: [id])
  student           Student                @relation(fields: [studentId], references: [id])
  uploadFiles       SubmitAssignmentFile[]

  @@index([classAssignmentId])
  @@index([studentId])
  @@map("submit_assignment")
}

model SubmitAssignmentFile {
  id                 String           @id @default(uuid())
  submitAssignmentId String
  fileUrl            String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  submitAssignment   SubmitAssignment @relation(fields: [submitAssignmentId], references: [id])

  @@index([submitAssignmentId])
  @@map("submit_assignment_files")
}

model ClassMaterial {
  id                  String            @id @default(uuid())
  materialType        ClassMaterialType
  description         String?
  materialFiles       String[]          @default([])
  external_link       String?
  classDistributionId String            @db.VarChar(255)
  subscriptionId      String            @db.VarChar(255)
  isDelete            Boolean           @default(false)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  classDistributions  ClassDistribution @relation(fields: [classDistributionId], references: [id])
  subscriptions       Subscriptions     @relation(fields: [subscriptionId], references: [id])

  @@index([materialType])
  @@index([classDistributionId])
  @@index([subscriptionId])
  @@map("class_materials")
}

model AttendanceSheet {
  id               String           @id @default(uuid())
  AttendanceDate   DateTime
  subscriptionId   String
  teacherId        String
  studentId        String
  attendanceStatus AttendanceStatus @default(ABSENT)
  isDelete         Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  students         Student          @relation(fields: [studentId], references: [id])
  subscriptions    Subscriptions    @relation(fields: [subscriptionId], references: [id])
  teachers         Teacher          @relation(fields: [teacherId], references: [id])

  @@unique([studentId, AttendanceDate, teacherId])
  @@index([teacherId])
  @@index([studentId])
  @@index([AttendanceDate])
  @@map("attendance_sheets")
}

// exam announcement
model ExamAnnouncement {
  id           String   @id @default(uuid())
  examDate     DateTime
  // tipTapEditor String
  examName     String?
  topic        String?
  totalMarks   String?
  duration     String?
  instruction  String?

  subscriptionId      String @db.VarChar(255)
  classDistributionId String @db.VarChar(255)

  subscription      Subscriptions     @relation(fields: [subscriptionId], references: [id])
  classDistribution ClassDistribution @relation(fields: [classDistributionId], references: [id])

  examGrades ExamGrades[]
  isCompleted     Boolean  @default(false)
  isDelete   Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([subscriptionId])
  @@index([classDistributionId])
  @@map("exam_announcements")
}

model ExamGrades {
  id String @id @default(uuid())

  examAnnouncementId String @db.VarChar(255)
  studentId          String @db.VarChar(255)
  teacherId          String

  totalMarks   Float
  marks        Float
  instructions String? @db.VarChar(555)

  students Student @relation(fields: [studentId], references: [id])
  teachers Teacher @relation(fields: [teacherId], references: [id])

  examAnnouncement ExamAnnouncement @relation(fields: [examAnnouncementId], references: [id])

  isDelete  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examAnnouncementId, studentId])
  @@index([studentId])
  @@index([teacherId])
  @@index([examAnnouncementId])
  @@map("exam_grades")
}

enum bloodTypeEnum {
  A_POSITIVE  @map("A+")
  A_NEGATIVE  @map("A-")
  B_POSITIVE  @map("B+")
  B_NEGATIVE  @map("B-")
  AB_POSITIVE @map("AB+")
  AB_NEGATIVE @map("AB-")
  O_POSITIVE  @map("O+")
  O_NEGATIVE  @map("O-")
}

model HealthRecords {
  id             String        @id @default(uuid())
  studentId      String        @db.VarChar(255)
  subscriptionId String        @db.VarChar(255)
  nurseId        String        @db.VarChar(255)
  students       Student       @relation(fields: [studentId], references: [id])
  subscription   Subscriptions @relation(fields: [subscriptionId], references: [id])
  nurses         Staff         @relation(fields: [nurseId], references: [id])

  bloodType        bloodTypeEnum
  tipTapEditor     String
  emergencyContact String
  isDelete         Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([studentId])
  @@index([subscriptionId])
  @@index([bloodType])
  @@index([emergencyContact])
  @@map("health_records")
}

model Admin {
  id          String   @id @default(uuid())
  fullName    String?
  phoneNumber String?
  email       String   @unique
  password    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("admins")
}
model mission {
   id          String   @id @default(uuid())
   mission String 
   isDelete         Boolean       @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
    @@map("mission")


}

model vision {
   id          String   @id @default(uuid())
   vision String 
   isDelete         Boolean       @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("vision")
}

model team {
    id          String   @id @default(uuid())
    name        String 
    designation String
    linkedinUrl   String
    whatsAppNumber  String
    photo   String
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    @@map("teams")
}

model FAQ {
   id          String   @id @default(uuid())
  question   String
  answer     String
  isDelete   Boolean
   createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    @@map("faqs")
}

model Blog {
   id          String   @id @default(uuid())
   blogCategory  String
   photo  String
   title String
   description  String

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    @@map("blogs")
}
model Newsletter {
  id          String   @id @default(uuid())
  email   String @unique

  createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    @@map("newsletters")
}


enum PaymentMethod {
  ONLINE
  MANUAL
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

enum AssignmentType {
  HomeWork
  Practice
  Project
  Quiz
}

enum ClassMaterialType {
  pdf
  word
  video
  external_link
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum UserRole {
  STUDENT
  parent
  TEACHER
  ADMIN
  SUPER_ADMIN
  INSTITUTIONAL_OWNER
  BRANCH_ADMIN
  NURSE
  BURSAR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  REJECTED
}

enum SubscriptionType {
  free_trial
  paid
}

enum SchoolArea {
  Urban
  Rural
}
